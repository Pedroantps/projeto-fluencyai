generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Entidade do Aluno
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  level     String   @default("B1")
  studyTime  Int      @default(30)
  createdAt DateTime @default(now())

  // Relacionamentos: Um usuário tem várias mensagens, flashcards e tarefas
  messages   Message[]
  flashcards Flashcard[]
  tasks      KanbanTask[]
  wordBank   WordBank[]
}

// 2. Histórico do Chat
model Message {
  id        String   @id @default(uuid())
  content   String   @db.Text
  role      Role     // Enum: USER ou ASSISTANT
  createdAt DateTime @default(now())

  // Chave estrangeira para o User
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relação 1 para 1 com a Correção (uma mensagem da IA pode ter uma correção)
  correction Correction?
}

enum Role {
  USER
  ASSISTANT
}

// 3. Notas da Professora (Teacher's Note)
model Correction {
  id          String @id @default(uuid())
  original    String @db.Text
  corrected   String @db.Text
  explanation String @db.Text

  // Chave estrangeira para a Message
  messageId   String  @unique
  message     Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// 4. Repositório de Palavras (Flashcards)
model Flashcard {
  id             String   @id @default(uuid())
  front          String   // A palavra em inglês
  back           String   // Tradução e explicação
  
  // NOVA COLUNA: Para saber de onde veio (chat, cronograma, aleatorio)
  source         String   @default("chat")
  
  // Campos para o algoritmo de repetição espaçada (como o Anki)
  nextReviewDate DateTime @default(now())
  interval       Int      @default(0) // Em dias
  easeFactor     Float    @default(2.5)
  
  createdAt      DateTime @default(now())

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 5. Cronograma de Estudos (Kanban)
model KanbanTask {
  id          String   @id @default(uuid())
  type        String   // "video", "flashcard" ou "chat"
  title       String
  description String?  @db.Text
  link        String?  // Link do YouTube
  duration    Int      @default(15) // Duração em minutos
  completed   Boolean  @default(false) // Substitui o enum, perfeito para a bolinha de check
  order       Int      @default(0) // Para o Drag and Drop saber a posição
  date        DateTime // Para saber em qual coluna (Dia da semana) ele vai ficar
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tabela temporária para guardar palavras do Chat
model WordBank {
  id        String   @id @default(uuid())
  word      String
  context   String?  @db.Text
  used      Boolean  @default(false) // Fica 'true' quando virar flashcard
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}